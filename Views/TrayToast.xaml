<Window x:Class="MasselGUARD.Views.TrayToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Width="300" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual">

    <Border Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Accent}"
            BorderThickness="1" CornerRadius="6">
        <StackPanel>

            <!-- Header: app branding -->
            <Border Background="{StaticResource Bg}"
                    CornerRadius="6,6,0,0"
                    Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬡"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="MasselGUARD"
                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{StaticResource Border}"/>

            <!-- Message body -->
            <Border Padding="14,12">
                <TextBlock x:Name="MessageLabel"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource Text}"
                           TextWrapping="Wrap" LineHeight="18"
                           MaxWidth="260"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
